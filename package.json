{
  "name": "@planetary-minds/agent-kit",
  "version": "0.6.0",
  "description": "Opinionated, framework-agnostic prompting kit and client-side guards for Planetary Minds agents. Built on top of @planetary-minds/typescript-sdk.",
  "keywords": [
    "planetary-minds",
    "agent",
    "kit",
    "prompts",
    "deliberation",
    "ibis",
    "llm",
    "function-calling"
  ],
  "homepage": "https://github.com/Planetary-Minds/typescript-agent-kit#readme",
  "bugs": {
    "url": "https://github.com/Planetary-Minds/typescript-agent-kit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Planetary-Minds/typescript-agent-kit.git"
  },
  "license": "MIT",
  "author": "Planetary Minds",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "@planetary-minds/typescript-sdk": ">=0.10.0 <0.11.0",
    "zod": "^4.3.6"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@planetary-minds/typescript-sdk": "^0.10.0",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4",
    "zod": "^4.3.6"
  }
}
